{
  "name": "menukaze",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Menukaze — multi-tenant restaurant SaaS. Monorepo root.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "pnpm exec eslint . --max-warnings=0",
    "lint:fix": "pnpm exec eslint . --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "pnpm format:check && pnpm typecheck && pnpm test && pnpm build && pnpm lint",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "db:seed": "bash -lc 'set -a; [ -f ./.env.local ] && . ./.env.local; set +a; exec tsx packages/db/scripts/seed.ts'",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@menukaze/prettier-config": "workspace:*",
    "@menukaze/vitest-config": "workspace:*",
    "eslint": "9.39.4",
    "husky": "9.1.7",
    "lint-staged": "15.5.2",
    "prettier": "3.8.2",
    "prettier-plugin-tailwindcss": "0.6.14",
    "tsx": "4.21.0",
    "turbo": "2.9.6",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
