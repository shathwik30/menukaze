# Menukaze env template. Copy to .env.local (gitignored) and fill in from your password manager.
# DO NOT commit .env.local.

# --- MongoDB Atlas ---
# https://cloud.mongodb.com  →  M0 free cluster  →  Drivers connect string
MONGODB_URI=
MONGODB_DB_LIVE=menukaze_live
MONGODB_DB_SANDBOX=menukaze_sandbox

# --- BetterAuth ---
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# --- Upstash Redis (production / staging) ---
# https://console.upstash.com  (capture REST + TCP endpoints; BullMQ needs TCP)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
UPSTASH_REDIS_TCP_URL=

# --- Local Redis (development) ---
# By default, points at the host Redis on :6379. If you'd rather use the
# dockerised Redis from docker-compose.yml, use redis://127.0.0.1:6380
REDIS_URL=redis://127.0.0.1:6379

# --- Ably ---
# https://ably.com  →  app keys
ABLY_API_KEY=
NEXT_PUBLIC_ABLY_CLIENT_ID_SALT=

# --- Resend ---
# https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_DOMAIN=onboarding@resend.dev

# --- UploadThing ---
# https://uploadthing.com  →  app settings
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# --- Razorpay (Test Mode) ---
# https://dashboard.razorpay.com  →  Account → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Encryption ---
# 32-byte base64 — AES-256-GCM envelope encryption for per-tenant Razorpay secrets
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# --- Sentry (one DSN per app) ---
SENTRY_DSN_STOREFRONT=
SENTRY_DSN_DASHBOARD=
SENTRY_DSN_QR_DINEIN=
SENTRY_DSN_KIOSK=
SENTRY_DSN_SUPER_ADMIN=
SENTRY_DSN_WORKER=

# --- Axiom ---
# https://app.axiom.co
AXIOM_DATASET=menukaze
AXIOM_TOKEN=

# --- MaxMind GeoLite2 ---
# https://www.maxmind.com/en/geolite2/signup
MAXMIND_LICENSE_KEY=

# --- Vercel / Fly (only needed for deploy CLIs) ---
VERCEL_TOKEN=
FLY_API_TOKEN=
