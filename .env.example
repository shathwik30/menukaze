# Menukaze — copy to .env.local and fill in values. Do NOT commit .env.local.

# MongoDB Atlas
MONGODB_URI=
MONGODB_DB_LIVE=menukaze_live
MONGODB_DB_SANDBOX=menukaze_sandbox

# BetterAuth — generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
SUPER_ADMIN_BETTER_AUTH_URL=http://localhost:3004
MENUKAZE_REQUIRE_EMAIL_VERIFICATION=false

# Upstash REST API — public API rate limiting (storefront /api/v1/*) plus
# per-IP throttling on the Ably token endpoints in storefront, qr-dinein and
# kiosk. Both vars are optional; if either is unset the rate-limiters become
# no-ops (safe for local dev and CI).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Kiosk app — staff exit PIN (4-6 digits). If unset, the exit overlay is
# permanently locked. Never defaults to a value.
KIOSK_EXIT_PIN=
KIOSK_RESTAURANT_SLUG=

# Ably (realtime)
ABLY_API_KEY=

# Encryption — generate: openssl rand -base64 32
ENCRYPTION_KEY=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_ADDRESS="Menukaze <noreply@menukaze.com>"
MENUKAZE_SKIP_EMAIL=false

# Razorpay — credentials are per-restaurant (entered during onboarding, stored encrypted in DB).
# This flag only skips the verification API call during onboarding in dev.
MENUKAZE_SKIP_RAZORPAY_VERIFICATION=false

# Worker — Fly.io health port. Set to 0 to disable the listener.
WORKER_HEALTH_PORT=8080
WORKER_SESSION_SWEEP_INTERVAL_MS=60000
WORKER_WEBHOOK_INTERVAL_MS=30000
