# Menukaze — copy to .env.local and fill in values. Do NOT commit .env.local.

# MongoDB Atlas
MONGODB_URI=
MONGODB_DB_LIVE=menukaze_live
MONGODB_DB_SANDBOX=menukaze_sandbox

# BetterAuth — generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
SUPER_ADMIN_BETTER_AUTH_URL=http://localhost:3004
MENUKAZE_REQUIRE_EMAIL_VERIFICATION=false

# Redis (Upstash or any Redis-compatible URL)
REDIS_URL=

# Ably (realtime)
ABLY_API_KEY=

# Encryption — generate: openssl rand -base64 32
ENCRYPTION_KEY=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_ADDRESS="Menukaze <noreply@menukaze.com>"
MENUKAZE_SKIP_EMAIL=false

# Razorpay — credentials are per-restaurant (entered during onboarding, stored encrypted in DB).
# This flag only skips the verification API call during onboarding in dev.
MENUKAZE_SKIP_RAZORPAY_VERIFICATION=false
