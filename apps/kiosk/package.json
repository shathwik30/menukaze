{
  "name": "@menukaze/kiosk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash -lc 'set -a; [ -f ../../.env.local ] && . ../../.env.local; set +a; exec next dev --port 3003'",
    "build": "bash -lc 'set -a; [ -f ../../.env.local ] && . ../../.env.local; set +a; exec next build'",
    "start": "bash -lc 'set -a; [ -f ../../.env.local ] && . ../../.env.local; set +a; exec next start --port 3003'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@menukaze/db": "workspace:*",
    "@menukaze/realtime": "workspace:*",
    "@menukaze/shared": "workspace:*",
    "@menukaze/tenant": "workspace:*",
    "@menukaze/ui": "workspace:*",
    "next": "16.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@menukaze/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "4.1.16",
    "@types/node": "22.12.0",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "tailwindcss": "4.1.16",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
