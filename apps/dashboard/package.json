{
  "name": "@menukaze/dashboard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash -lc 'set -a; [ -f ../../.env.local ] && . ../../.env.local; set +a; exec next dev --port 3000'",
    "build": "bash -lc 'set -a; [ -f ../../.env.local ] && . ../../.env.local; set +a; exec next build'",
    "start": "bash -lc 'set -a; [ -f ../../.env.local ] && . ../../.env.local; set +a; exec next start --port 3000'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@menukaze/auth": "workspace:*",
    "@menukaze/db": "workspace:*",
    "@menukaze/rbac": "workspace:*",
    "@menukaze/realtime": "workspace:*",
    "@menukaze/shared": "workspace:*",
    "@menukaze/tenant": "workspace:*",
    "@menukaze/ui": "workspace:*",
    "@react-email/render": "1.0.3",
    "ably": "2.7.0",
    "better-auth": "1.5.6",
    "mongoose": "9.4.1",
    "next": "16.2.3",
    "pdf-lib": "1.17.1",
    "qrcode": "1.5.4",
    "qrcode.react": "4.2.0",
    "razorpay": "2.9.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "resend": "4.0.1",
    "zod": "4.2.0"
  },
  "devDependencies": {
    "@menukaze/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "4.1.16",
    "@types/node": "22.12.0",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "tailwindcss": "4.1.16",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
